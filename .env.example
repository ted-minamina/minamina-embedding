# TEI embedding service (MiniLM-L12-v2, 384-dim, mean pooling)
TEI_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TEI_EMBEDDING_DIM=384
TEI_PORT=8400

# Clients (minamina-chat, mem0) connect via:
# TEI_URL=http://127.0.0.1:8400        # host
# TEI_URL=http://tei:80                # same Docker network
